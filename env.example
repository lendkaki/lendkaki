# Copy to .env.local and fill in values.
# Optional: protect /api/leads so only requests with this key are accepted.
# Use a long random string (e.g. openssl rand -hex 32).
# Note: This value is sent by the frontend, so it is visible in the browser. It still blocks callers who don't know the key.
NEXT_PUBLIC_LEADS_API_KEY=

# Supabase (required for saving leads to DB)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
